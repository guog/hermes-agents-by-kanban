+_sdd_completion_validator_cache: tuple[str, Any] | None = None
+
+
+class CompletionMetadataValidationError(ValueError):
+    """Raised before a formal SDD card can persist an invalid handoff."""
+
+    def __init__(self, task_id: str, errors: Iterable[str]):
+        self.task_id = task_id
+        self.errors = [str(error) for error in errors]
+        super().__init__(
+            f"formal SDD completion metadata for {task_id} is invalid: "
+            + "; ".join(self.errors)
+        )
+
+
+def _load_sdd_completion_validator():
+    global _sdd_completion_validator_cache
+    validator_path = os.environ.get(
+        "HERMES_SDD_COMPLETION_VALIDATOR",
+        _SDD_COMPLETION_VALIDATOR_DEFAULT,
+    )
+    if (
+        _sdd_completion_validator_cache is not None
+        and _sdd_completion_validator_cache[0] == validator_path
+    ):
+        return _sdd_completion_validator_cache[1]
+
+    spec = importlib.util.spec_from_file_location(
+        "hermes_sdd_completion_validator",
+        validator_path,
+    )
+    if spec is None or spec.loader is None:
+        raise RuntimeError(
+            f"cannot load SDD completion validator from {validator_path}"
+        )
+    module = importlib.util.module_from_spec(spec)
+    spec.loader.exec_module(module)
+    if not callable(getattr(module, "validate_completion_metadata", None)):
+        raise RuntimeError(
+            f"SDD completion validator {validator_path} has no "
+            "validate_completion_metadata function"
+        )
+    _sdd_completion_validator_cache = (validator_path, module)
+    return module
+
+
+def _validate_formal_sdd_completion(
+    conn: sqlite3.Connection,
+    task_id: str,
+    metadata: Optional[dict],
+) -> None:
+    row = conn.execute(
+        "SELECT body, created_by FROM tasks WHERE id = ?",
+        (task_id,),
+    ).fetchone()
+    if row is None or SDD_COMPLETION_SCHEMA_MARKER not in (row["body"] or ""):
+        return
+    if row["created_by"] != "dispatcher":
+        raise CompletionMetadataValidationError(
+            task_id,
+            [
+                "formal SDD cards must have tasks.created_by='dispatcher', "
+                f"got {row['created_by']!r}"
+            ],
+        )
+
+    schema_path = os.environ.get(
+        "HERMES_SDD_COMPLETION_SCHEMA",
+        _SDD_COMPLETION_SCHEMA_DEFAULT,
+    )
+    try:
+        validator = _load_sdd_completion_validator()
+        errors = validator.validate_completion_metadata(
+            metadata,
+            task_id=task_id,
+            schema_path=schema_path,
+        )
+    except CompletionMetadataValidationError:
+        raise
+    except Exception as exc:
+        raise CompletionMetadataValidationError(
+            task_id,
+            [f"completion validator unavailable: {exc}"],
+        ) from exc
+    if errors:
+        raise CompletionMetadataValidationError(task_id, errors)
+
+
