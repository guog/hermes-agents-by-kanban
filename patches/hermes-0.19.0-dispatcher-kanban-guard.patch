+def _require_dispatcher_profile(tool_name: str) -> Optional[str]:
+    """Fleet hardening: only the named dispatcher may shape the task graph."""
+    profile = (os.environ.get("HERMES_PROFILE") or "").strip()
+    if profile != "dispatcher":
+        return tool_error(
+            f"{tool_name} is restricted to HERMES_PROFILE=dispatcher; "
+            f"caller profile was {profile or '<unset>'}."
+        )
+    return None
+
