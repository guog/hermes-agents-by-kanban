# Copy this file to .env and edit it before the first docker compose up.
COMPOSE_PROJECT_NAME=hermes-sdd

# Official Hermes Agent image, pinned to the reviewed Linux AMD64 manifest.
HERMES_IMAGE=nousresearch/hermes-agent:v2026.7.20@sha256:a6ce64e2038867885c2c90f6602425e6e70293d5e6d952a0e603a99265e01c40

# Writable host directories mounted into the official image.
HERMES_DATA_DIR=./data
PROJECTS_DIR=./projects
PUID=1000
PGID=1000

# Dashboard is published on every host interface. Its username, plaintext
# password, and session secret are edited directly in docker-compose.yaml.
HERMES_DASHBOARD_PORT=9119

# Shared model-provider credentials. Profile-specific GitLab and Feishu
# credentials must stay in data/profiles/<profile>/.env.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
NOUS_API_KEY=
