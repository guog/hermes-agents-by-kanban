# Docker runtime
COMPOSE_PROJECT_NAME=hermes-sdd
HERMES_BASE_IMAGE=nousresearch/hermes-agent@sha256:3dcdb7b88092fc18846ba0276a84ccf86cfd9afebc83ed8f98cdd0e78bf46e69
HERMES_DATA_DIR=./.runtime/hermes
PROJECTS_DIR=./.runtime/projects
HERMES_DASHBOARD_PORT=9119
PUID=1000
PGID=1000

# Model. Use one model identifier accepted by `hermes config set model`.
FLEET_MODEL=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
NOUS_API_KEY=

# GitLab
GITLAB_HOST=gitlab.example.internal
GITLAB_TOKEN_DISPATCHER=
GITLAB_TOKEN_PRD_WRITER=
GITLAB_TOKEN_FDE=
GITLAB_TOKEN_SPEC_WRITER=
GITLAB_TOKEN_SPEC_REVIEWER=
GITLAB_TOKEN_PLANNER=
GITLAB_TOKEN_PLAN_REVIEWER=
GITLAB_TOKEN_TASKER=
GITLAB_TOKEN_TASK_REVIEWER=
GITLAB_TOKEN_CODER=
GITLAB_TOKEN_TESTER=
GITLAB_TOKEN_CODE_REVIEWER=

# Commit identities for profiles that write branches.
GIT_COMMIT_NAME_PRD_WRITER="Hermes PRD Writer"
GIT_COMMIT_EMAIL_PRD_WRITER=
GIT_COMMIT_NAME_FDE="Hermes FDE"
GIT_COMMIT_EMAIL_FDE=
GIT_COMMIT_NAME_SPEC_WRITER="Hermes SPEC Writer"
GIT_COMMIT_EMAIL_SPEC_WRITER=
GIT_COMMIT_NAME_PLANNER="Hermes Planner"
GIT_COMMIT_EMAIL_PLANNER=
GIT_COMMIT_NAME_TASKER="Hermes Tasker"
GIT_COMMIT_EMAIL_TASKER=
GIT_COMMIT_NAME_CODER="Hermes Coder"
GIT_COMMIT_EMAIL_CODER=

# Dispatcher Feishu/Lark bot. Other profiles never receive these values.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_DOMAIN=feishu
FEISHU_CONNECTION_MODE=websocket
FEISHU_ALLOWED_USERS=ou_replace_me
FEISHU_HOME_CHANNEL=oc_replace_me
FEISHU_GROUP_POLICY=allowlist
FEISHU_REQUIRE_MENTION=true

# Fleet bootstrap. Set force-config to 1 only when accepting new managed config.
FLEET_FORCE_CONFIG=0
FLEET_SYNC_SECRETS=1
