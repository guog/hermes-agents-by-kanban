# Docker runtime
COMPOSE_PROJECT_NAME=hermes-sdd
# The official image must already exist locally; Compose never builds or pulls it.
HERMES_IMAGE=nousresearch/hermes-agent:v2026.7.20
TOOLING_VOLUME_NAME=hermes-sdd-tooling
HERMES_DATA_DIR=./.runtime/hermes
PROJECTS_DIR=./.runtime/projects
HERMES_DASHBOARD_PORT=9119
PUID=1000
PGID=1000

# Model. Use one model identifier accepted by `hermes config set model`.
FLEET_MODEL=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
NOUS_API_KEY=

# Commit identities for profiles that write branches. FDE only creates Issues.
# The reserved .invalid domain is deliberately non-deliverable and marks these as bot identities.
# If GitLab enforces verified committer emails, replace them with verified bot no-reply aliases.
GIT_COMMIT_NAME_PRD_WRITER="Hermes PRD Writer"
GIT_COMMIT_EMAIL_PRD_WRITER=prd-writer-bot@hermes.invalid
GIT_COMMIT_NAME_SPEC_WRITER="Hermes SPEC Writer"
GIT_COMMIT_EMAIL_SPEC_WRITER=spec-writer-bot@hermes.invalid
GIT_COMMIT_NAME_PLANNER="Hermes Planner"
GIT_COMMIT_EMAIL_PLANNER=planner-bot@hermes.invalid
GIT_COMMIT_NAME_TASKER="Hermes Tasker"
GIT_COMMIT_EMAIL_TASKER=tasker-bot@hermes.invalid
GIT_COMMIT_NAME_CODER="Hermes Coder"
GIT_COMMIT_EMAIL_CODER=coder-bot@hermes.invalid

# GitLab and Feishu credentials belong only in HERMES_DATA_DIR/profiles/<profile>/.env.
# Set force-config to 1 only when accepting new managed profile configuration.
FLEET_FORCE_CONFIG=0
