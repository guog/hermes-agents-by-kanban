{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/card-completion.schema.json",
  "title": "Hermes SDD Kanban Card Completion v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_key",
    "stage",
    "outcome",
    "project_id",
    "project_path",
    "project_display_name",
    "checkout",
    "worktree",
    "branch",
    "target_branch",
    "prd_path",
    "prd_commit_sha",
    "prd_mr_url",
    "kanban_card_id",
    "mr_iid",
    "mr_url",
    "head_sha",
    "artifact_paths",
    "artifact_digest",
    "verification",
    "residual_risk"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "run_key": {"type": "string", "pattern": "^sdd-[a-z2-7]{20}$"},
    "stage": {
      "type": "string",
      "enum": [
        "run-init", "spec-write", "spec-review", "spec-gate", "spec-rework",
        "plan-write", "plan-review", "plan-gate", "plan-rework",
        "tasks-write", "tasks-review", "tasks-gate", "tasks-rework",
        "implement", "test", "test-gate", "code-review", "code-gate",
        "code-rework", "merge", "run-complete", "human-decision"
      ]
    },
    "outcome": {
      "type": "string",
      "enum": ["pass", "fail", "scope_gap", "blocked", "cancelled"]
    },
    "project_id": {"type": "integer", "minimum": 1},
    "project_path": {"type": "string", "pattern": "^[^/]+/.+$"},
    "project_display_name": {"type": "string", "minLength": 1},
    "checkout": {"type": "string", "pattern": "^/workspace/projects/p[1-9][0-9]*-"},
    "worktree": {"type": "string", "pattern": "^/workspace/projects/worktrees/p[1-9][0-9]*/sdd-"},
    "branch": {"type": "string", "minLength": 3},
    "target_branch": {"type": "string", "minLength": 1},
    "prd_path": {"type": "string", "pattern": "^docs/prds/prd-[a-z0-9]+(?:-[a-z0-9]+)*\\.md$"},
    "prd_commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "prd_mr_url": {"type": "string", "format": "uri"},
    "iteration": {"type": "integer", "minimum": 1},
    "kanban_card_id": {"type": "string", "pattern": "^t_[A-Za-z0-9_-]+$"},
    "mr_iid": {"type": ["integer", "null"], "minimum": 1},
    "mr_url": {"type": ["string", "null"], "format": "uri"},
    "head_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "review_commit_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "checked_head": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "merge_commit_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "artifact_digest": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "artifact_paths": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "verification": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "gitlab_urls": {
      "type": "array",
      "items": {"type": "string", "format": "uri"},
      "uniqueItems": true
    },
    "next_card_ids": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "retry_notes": {"type": ["string", "null"]},
    "residual_risk": {"type": "array", "items": {"type": "string"}}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "stage": {"enum": ["spec-review", "plan-review", "tasks-review"]},
          "outcome": {"const": "pass"}
        },
        "required": ["stage", "outcome"]
      },
      "then": {
        "required": ["artifact_paths", "artifact_digest", "review_commit_sha"],
        "properties": {
          "artifact_paths": {"type": "array", "minItems": 1},
          "artifact_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "review_commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
        }
      }
    },
    {
      "if": {
        "properties": {
          "stage": {"enum": ["test", "code-review"]},
          "outcome": {"const": "pass"}
        },
        "required": ["stage", "outcome"]
      },
      "then": {
        "required": ["head_sha", "mr_iid", "mr_url"],
        "properties": {
          "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
          "mr_iid": {"type": "integer", "minimum": 1},
          "mr_url": {"type": "string", "format": "uri"}
        }
      }
    },
    {
      "if": {
        "properties": {
          "stage": {"const": "merge"}
        },
        "required": ["stage"]
      },
      "then": {
        "$comment": "Dispatcher must also reject unless head_sha equals checked_head and the GitLab merge request used sha=checked_head.",
        "required": ["head_sha", "checked_head", "mr_iid", "mr_url"],
        "properties": {
          "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
          "checked_head": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
          "mr_iid": {"type": "integer", "minimum": 1},
          "mr_url": {"type": "string", "format": "uri"}
        }
      }
    },
    {
      "if": {
        "properties": {
          "stage": {"const": "merge"},
          "outcome": {"const": "pass"}
        },
        "required": ["stage", "outcome"]
      },
      "then": {
        "required": ["merge_commit_sha"],
        "properties": {
          "merge_commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
        }
      }
    }
  ]
}
